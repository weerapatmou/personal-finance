# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://user:pass@host:5432/finance"
DIRECT_URL="postgresql://user:pass@host:5432/finance"

# ─── Auth.js ─────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET="generate-with-openssl-rand-base64-32"
AUTH_URL="http://localhost:3000"

# ─── Email (magic-link auth) ─────────────────────────────────────────────────
EMAIL_SERVER="smtp://user:apikey@smtp.resend.com:465"
EMAIL_FROM="finance@yourdomain.com"
ALLOWED_EMAIL="you@example.com"

# ─── Cron routes ─────────────────────────────────────────────────────────────
CRON_SECRET="generate-a-long-random-string"

# ─── Seed defaults (db:seed) ─────────────────────────────────────────────────
SEED_USERNAME="weerapat"
SEED_PASSWORD="weerapatmou"
SEED_NAME="Weerapat"

# ─── App config ──────────────────────────────────────────────────────────────
OVER_BUDGET_THRESHOLD_PCT="10"

# ─── Backups (Phase 2 enables these; leave empty to keep cron in skip mode) ──
BACKUP_S3_ENDPOINT=""
BACKUP_S3_BUCKET=""
BACKUP_S3_KEY=""
BACKUP_S3_SECRET=""
