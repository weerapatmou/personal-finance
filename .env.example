# Database (Supabase or Neon Postgres)
DATABASE_URL="postgresql://user:pass@host:5432/finance"
DIRECT_URL="postgresql://user:pass@host:5432/finance"

# Auth.js
AUTH_SECRET="generate-with-openssl-rand-base64-32"
AUTH_URL="http://localhost:3000"
EMAIL_SERVER="smtp://resend:RESEND_API_KEY@smtp.resend.com:465"
EMAIL_FROM="finance@yourdomain.com"

# Allowlisted login email
ALLOWED_EMAIL="you@example.com"

# Seed data
SEED_EMAIL="you@example.com"
SEED_NAME="Your Name"

# Cron
CRON_SECRET="generate-a-long-random-string"

# Backups (filled in Phase 2 when pg_dump body lands)
BACKUP_S3_ENDPOINT=""
BACKUP_S3_BUCKET=""
BACKUP_S3_KEY=""
BACKUP_S3_SECRET=""

# Over-budget threshold for highlighting (percent, default 10)
OVER_BUDGET_THRESHOLD_PCT="10"
